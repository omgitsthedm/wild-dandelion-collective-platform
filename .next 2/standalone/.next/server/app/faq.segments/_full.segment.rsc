14:["$","div",null,{"className":"Footer-module__k1zZxa__contactBar","children":[["$","div",null,{"className":"Footer-module__k1zZxa__contactItem","children":[["$","span",null,{"className":"Footer-module__k1zZxa__contactIcon","children":"📍"}],["$","span",null,{"children":"413 Main St, Longmont, CO 80501"}]]}],["$","div",null,{"className":"Footer-module__k1zZxa__contactDivider"}],["$","div",null,{"className":"Footer-module__k1zZxa__contactItem","children":[["$","span",null,{"className":"Footer-module__k1zZxa__contactIcon","children":"📞"}],["$","a",null,{"href":"tel:+13038347572","children":"(303) 834-7572"}]]}],["$","div",null,{"className":"Footer-module__k1zZxa__contactDivider"}],["$","div",null,{"className":"Footer-module__k1zZxa__contactItem","children":[["$","span",null,{"className":"Footer-module__k1zZxa__contactIcon","children":"✉️"}],["$","a",null,{"href":"mailto:hello@thewilddandelion.com","children":"hello@thewilddandelion.com"}]]}],["$","div",null,{"className":"Footer-module__k1zZxa__contactDivider"}],["$","div",null,{"className":"Footer-module__k1zZxa__contactItem","children":[["$","span",null,{"className":"Footer-module__k1zZxa__contactIcon","children":"🕐"}],["$","span",null,{"children":"Mon–Sat: 9am–7pm"}]]}]]}]
15:["$","div",null,{"className":"Footer-module__k1zZxa__bottom","children":[["$","p",null,{"className":"Footer-module__k1zZxa__copyright","children":["© ",2026," The Wild Dandelion Collective. All rights reserved."]}],["$","p",null,{"className":"Footer-module__k1zZxa__attribution","children":["Made with 💕 by"," ",["$","a",null,{"href":"https://littlefightnyc.com","target":"_blank","rel":"noopener noreferrer","children":"LittleFightNYC"}]]}]]}]
