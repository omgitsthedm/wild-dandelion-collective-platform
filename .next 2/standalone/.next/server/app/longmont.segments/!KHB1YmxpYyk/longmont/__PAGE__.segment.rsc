0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"LocalBusiness\",\"name\":\"The Wild Dandelion Collective\",\"description\":\"A premier hair salon on Main Street in Longmont, Colorado offering precision cuts, lived-in color, extensions, and bridal styling.\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"528 Main St\",\"addressLocality\":\"Longmont\",\"addressRegion\":\"CO\",\"postalCode\":\"80501\",\"addressCountry\":\"US\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":40.1672,\"longitude\":-105.1019},\"telephone\":\"+1-303-555-0198\",\"priceRange\":\"$$\",\"openingHoursSpecification\":[{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\"opens\":\"09:00\",\"closes\":\"18:00\"},{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":\"Saturday\",\"opens\":\"09:00\",\"closes\":\"15:00\"}],\"url\":\"https://thewilddandelioncollective.com/longmont\"}"}}],["$","main",null,{"className":"page-module__sk31tW__page","children":["$","div",null,{"className":"page-module__sk31tW__container","children":[["$","div",null,{"className":"SectionHeader-module__UrgnEa__wrapper ","children":[["$","p",null,{"className":"SectionHeader-module__UrgnEa__eyebrow","children":"Longmont, Colorado"}],["$","h2",null,{"className":"SectionHeader-module__UrgnEa__title","children":"Hair Care on Main Street"}],["$","hr",null,{"className":"SectionHeader-module__UrgnEa__divider"}]]}],["$","h1",null,{"className":"page-module__sk31tW__seoHeading","children":"Hair Salon in Longmont"}],["$","div",null,{"className":"page-module__sk31tW__content","children":[["$","div",null,{"className":"page-module__sk31tW__copy","children":[["$","p",null,{"children":"Tucked along the heart of Longmont’s Main Street, The Wild Dandelion Collective sits among the independent shops, cafes, and galleries that make this stretch of town feel like something worth preserving. When you walk through our door, you leave the noise behind and step into a space that was designed to feel personal, unhurried, and entirely yours."}],["$","p",null,{"children":"This is not a high-volume salon. Every appointment is one-on-one with your stylist in a private suite — no assembly lines, no rushed color applications, no waiting in a crowded lobby. That intimacy is the whole point."}],["$","h3",null,{"className":"page-module__sk31tW__subheading","children":"Services available"}],["$","ul",null,{"className":"page-module__sk31tW__serviceList","children":[["$","li",null,{"children":"Precision haircuts and restorative treatments"}],["$","li",null,{"children":"Lived-in blonde and balayage"}],["$","li",null,{"children":"Signature color and corrective color"}],["$","li",null,{"children":"Hand-tied and tape-in extensions"}],["$","li",null,{"children":"Bridal and special occasion styling"}]]}],["$","h3",null,{"className":"page-module__sk31tW__subheading","children":"Part of the community"}],["$","p",null,{"children":"Ashley built The Wild Dandelion here because Longmont is home. This is a place where neighbors become clients and clients become friends. We care about this town — we shop on Main Street, we run into you at the farmers market, and we take pride in being part of what makes this community thrive."}]]}],["$","aside",null,{"className":"page-module__sk31tW__details","children":[["$","div",null,{"className":"page-module__sk31tW__detailBlock","children":[["$","h3",null,{"className":"page-module__sk31tW__detailLabel","children":"Address"}],["$","p",null,{"className":"page-module__sk31tW__detailText","children":["528 Main St",["$","br",null,{}],"Longmont, CO 80501"]}]]}],["$","div",null,{"className":"page-module__sk31tW__detailBlock","children":[["$","h3",null,{"className":"page-module__sk31tW__detailLabel","children":"Hours"}],"$L2"]}],"$L3"]}]]}]]}]}]],["$L4"],"$L5"]}],"isPartial":false,"staleTime":300,"varyParams":nul