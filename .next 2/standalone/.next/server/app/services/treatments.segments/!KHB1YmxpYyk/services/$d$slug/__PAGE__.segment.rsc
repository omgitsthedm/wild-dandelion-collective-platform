0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"page-module__fov6ZW__page","children":["$","div",null,{"className":"page-module__fov6ZW__container","children":[["$","div",null,{"className":"page-module__fov6ZW__hero","children":["$","$L2",null,{"src":"/images/hair-work-2.webp","alt":"Treatments","developing":true,"className":"page-module__fov6ZW__heroFrame"}]}],["$","div",null,{"className":"page-module__fov6ZW__header","children":[["$","p",null,{"className":"page-module__fov6ZW__category","children":"Treatments"}],["$","h1",null,{"className":"page-module__fov6ZW__title","children":"Treatments"}]]}],["$","div",null,{"className":"page-module__fov6ZW__content","children":[["$","section",null,{"children":[["$","h2",null,{"className":"page-module__fov6ZW__sectionHeading","children":"What it is"}],["$","p",null,{"className":"page-module__fov6ZW__sectionBody","children":"The Wild Dandelion offers two signature treatment services. Liquid Luster is a gloss treatment that adds intense shine, smooths the cuticle, and refreshes tone — think of it as a facial for your hair. Kera/RX Keraplasty is a deeper restorative treatment that repairs damage from chemical services, heat styling, and environmental stress by rebuilding the hair from the inside out. Both use professional-grade formulations and can be added to any service or booked standalone."}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"page-module__fov6ZW__sectionHeading","children":"Who it’s for"}],["$","p",null,{"className":"page-module__fov6ZW__sectionBody","children":"Liquid Luster is for anyone who wants a visible boost in shine and softness — it is especially good between color appointments. Keraplasty is for hair that feels dry, damaged, or compromised from repeated processing. If your hair has lost its elasticity or feels brittle, this treatment can make a dramatic difference."}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"page-module__fov6ZW__sectionHeading","children":"What to expect"}],["$","p",null,{"className":"page-module__fov6ZW__sectionBody","children":"Both treatments are applied at the shampoo bowl after your hair has been cleansed. Liquid Luster processes quickly and delivers immediate shine. Keraplasty requires a longer processing time and may involve heat to help the formula penetrate. You will feel the difference the moment your hair is rinsed — smoother, stronger, and noticeably healthier."}]]}]]}],["$","div",null,{"className":"page-module__fov6ZW__infoBlock","children":[["$","div",null,{"className":"page-module__fov6ZW__infoItem","children":[["$","span",null,{"className":"page-module__fov6ZW__infoLabel","children":"Pricing"}],["$","span",null,{"className":"page-module__fov6ZW__infoValue","children":"Starting at $45"}]]}],["$","div",null,{"className":"page-module__fov6ZW__infoDivider"}],["$","div",null,{"className":"page-module__fov6ZW__infoItem","children":[["$","span",null,{"className":"page-module__fov6ZW__infoLabel","children":"Duration"}],["$","span",null,{"className":"page-module__fov6ZW__infoValue","children":"30 min - 1 hr"}]]}]]}],["$","div",null,{"className":"page-module__fov6ZW__cta","children":["$","a",null,{"href":"/book","className":"Button-module__zVQJKW__button Button-module__zVQJKW__primary Button-module__zVQJKW__fullWidth","children":"Book This Service"}]}],["$","aside",null,{"className":"page-module__fov6ZW__ashleyNote","children":[["$","p",null,{"className":"page-module__fov6ZW__noteLabel","children":"A note from Ashley"}],["$","p",null,{"className":"page-module__fov6ZW__noteText","children":"I am a big believer in treating your hair like you treat your skin — it needs regular care, not just color. These treatments are the kind of thing you will not realize you needed until you feel the difference. I recommend them to almost everyone."}]]}]]}]}],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/0~ww8ls-m-185.css","precedence":"next"}],"$L3","$L4"],"$L5"]}],"isPartial"