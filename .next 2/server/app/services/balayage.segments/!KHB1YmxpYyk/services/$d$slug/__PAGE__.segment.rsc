0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"page-module__fov6ZW__page","children":["$","div",null,{"className":"page-module__fov6ZW__container","children":[["$","div",null,{"className":"page-module__fov6ZW__hero","children":["$","$L2",null,{"src":"/images/hair-work-1.webp","alt":"Balayage / Ombre","developing":true,"className":"page-module__fov6ZW__heroFrame"}]}],["$","div",null,{"className":"page-module__fov6ZW__header","children":[["$","p",null,{"className":"page-module__fov6ZW__category","children":"Blonde & Highlights"}],["$","h1",null,{"className":"page-module__fov6ZW__title","children":"Balayage / Ombre"}]]}],["$","div",null,{"className":"page-module__fov6ZW__content","children":[["$","section",null,{"children":[["$","h2",null,{"className":"page-module__fov6ZW__sectionHeading","children":"What it is"}],["$","p",null,{"className":"page-module__fov6ZW__sectionBody","children":"Balayage is a hand-painting technique where color is swept onto the hair surface rather than saturated through foils. This creates a softer, more gradual transition from your natural root to lighter ends. Ombre is a similar concept with a more defined contrast between dark and light. Ashley uses both approaches — and often combines them — depending on the effect you are after."}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"page-module__fov6ZW__sectionHeading","children":"Who it’s for"}],["$","p",null,{"className":"page-module__fov6ZW__sectionBody","children":"Anyone who loves the look of naturally sun-lightened hair with soft, blended transitions. Balayage is ideal if you want brightness without a visible grow-out line. It is also a great option if you are new to lightening and want to start gradually."}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"page-module__fov6ZW__sectionHeading","children":"What to expect"}],["$","p",null,{"className":"page-module__fov6ZW__sectionBody","children":"Ashley paints your hair freehand, which requires a different kind of precision than foils. She works section by section, building up brightness where the light would naturally hit. Processing times vary. The appointment finishes with toning, a treatment, and styling."}]]}]]}],["$","div",null,{"className":"page-module__fov6ZW__infoBlock","children":[["$","div",null,{"className":"page-module__fov6ZW__infoItem","children":[["$","span",null,{"className":"page-module__fov6ZW__infoLabel","children":"Pricing"}],["$","span",null,{"className":"page-module__fov6ZW__infoValue","children":"Starting at $225"}]]}],["$","div",null,{"className":"page-module__fov6ZW__infoDivider"}],["$","div",null,{"className":"page-module__fov6ZW__infoItem","children":[["$","span",null,{"className":"page-module__fov6ZW__infoLabel","children":"Duration"}],["$","span",null,{"className":"page-module__fov6ZW__infoValue","children":"2 hr 30 min+"}]]}]]}],["$","div",null,{"className":"page-module__fov6ZW__cta","children":["$","a",null,{"href":"/book","className":"Button-module__zVQJKW__button Button-module__zVQJKW__primary Button-module__zVQJKW__fullWidth","children":"Book This Service"}]}],["$","aside",null,{"className":"page-module__fov6ZW__ashleyNote","children":[["$","p",null,{"className":"page-module__fov6ZW__noteLabel","children":"A note from Ashley"}],["$","p",null,{"className":"page-module__fov6ZW__noteText","children":"Balayage is where artistry really comes in. There is no foil guiding the placement — it is all in the hand. I love this technique because every result is completely unique to the person in my chair."}]]}]]}]}],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/0~ww8ls-m-185.css","precedence":"next"}],["$","link","1",{"rel":"stylesheet","href":"/_next/static/chunks/0u4.swdsoosqq.css","precedence":"next"}],["$","script","script-0",{"src":"/_next/static/chunks/17atglk0iug8t.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":false,