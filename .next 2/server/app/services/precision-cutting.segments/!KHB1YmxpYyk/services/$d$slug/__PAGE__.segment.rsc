n at the chair where Ashley assesses your hair and talks through what you are looking for. The cut itself is precise and unhurried. She will finish with styling so you can see the shape in motion. Expect to leave with tips on how to maintain it at home."}]]}]]}],["$","div",null,{"className":"page-module__fov6ZW__infoBlock","children":[["$","div",null,{"className":"page-module__fov6ZW__infoItem","children":[["$","span",null,{"className":"page-module__fov6ZW__infoLabel","children":"Pricing"}],["$","span",null,{"className":"page-module__fov6ZW__infoValue","children":"Starting at $85"}]]}],["$","div",null,{"className":"page-module__fov6ZW__infoDivider"}],["$","div",null,{"className":"page-module__fov6ZW__infoItem","children":[["$","span",null,{"className":"page-module__fov6ZW__infoLabel","children":"Duration"}],["$","span",null,{"className":"page-module__fov6ZW__infoValue","children":"30 min+"}]]}]]}],["$","div",null,{"className":"page-module__fov6ZW__cta","children":["$","a",null,{"href":"/book","className":"Button-module__zVQJKW__button Button-module__zVQJKW__primary Button-module__zVQJKW__fullWidth","children":"Book This Service"}]}],["$","aside",null,{"className":"page-module__fov6ZW__ashleyNote","children":[["$","p",null,{"className":"page-module__fov6ZW__noteLabel","children":"A note from Ashley"}],["$","p",null,{"className":"page-module__fov6ZW__noteText","children":"A great cut is the foundation of everything. I trained at Sassoon because I believe in structure — when the bones are right, everything else falls into place. I will never rush this."}]]}]]}]}],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/0~ww8ls-m-185.css","precedence":"next"}],["$","link","1",{"rel":"stylesheet","href":"/_next/static/chunks/0u4.swdsoosqq.css","precedence":"next"}],["$","script","script-0",{"src":"/_next/static/chunks/17atglk0iug8t.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":fal