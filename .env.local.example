# ── Required for core functionality ──────────────────

# Turso Database
# Get these from https://turso.tech after creating a database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Square (source of truth for bookings, catalog, customers)
# Get these from https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=sq0idp-xxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXXXXXXXXX
SQUARE_ENVIRONMENT=sandbox  # Change to "production" when ready

# Admin Authentication
# Generate with: node -e "const {randomBytes,scrypt}=require('crypto');const s=randomBytes(16).toString('hex');scrypt('YOUR_PASSWORD',s,64,(e,d)=>console.log(s+':'+d.toString('hex')));"
ADMIN_PASSWORD_HASH=salt:hash

# ── Required for notifications ───────────────────────

ASHLEY_PHONE_NUMBER=+13035551234
ASHLEY_EMAIL=ashley@thewilddandelioncollective.com
FROM_EMAIL=hello@thewilddandelioncollective.com

# ── Integration credentials (wire when ready) ────────

# Resend (email) - https://resend.com
RESEND_API_KEY=re_xxxxxxxx

# Twilio (SMS) - https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+13035551234

# Stripe (payments) - https://stripe.com
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# ── Auto-set by Netlify (no manual config needed) ────

# NETLIFY_BLOBS_TOKEN=auto
# NETLIFY_SITE_ID=auto

# ── Site configuration ───────────────────────────────

NEXT_PUBLIC_URL=http://localhost:3000  # Change to production URL when deployed
